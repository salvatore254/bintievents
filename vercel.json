{
  "version": 2,
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/(.+\\.(js|css|json|ico|png|jpg|jpeg|gif|svg|woff|woff2))",
      "dest": "/$1",
      "headers": {
        "cache-control": "public, max-age=31536000"
      }
    },
    {
      "src": "/api/(.*)",
      "dest": "https://binti-backend-production.up.railway.app/api/$1"
    },
    {
      "src": "^/(.+)\\.html$",
      "dest": "/$1.html"
    },
    {
      "src": "^/(?!.*\\.).*$",
      "dest": "/index.html"
    }
  ]
}

